{
    "manifest_version": 3,
    "name": "ScholarMatch Co-Pilot",
    "version": "1.0",
    "description": "Your AI Scholarship Application Assistant",
    "permissions": [
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "https://*.gov.in/*",
        "https://vemskadgdfktywjodxop.supabase.co/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.gov.in/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "style.css"
            ]
        }
    ]
}